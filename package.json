{
  "name": "ai-slide-design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run render && slidev decks/ai-governance/slides.md",
    "content:build": "node scripts/render-content.mjs",
    "content:check": "node scripts/render-content.mjs --check",
    "content:test": "node scripts/test-content-markdown.mjs",
    "content:pptx": "npm run pptx:build",
    "render": "npm run content:build && node scripts/render-slidev.mjs",
    "render:check": "node scripts/render-slidev.mjs --check",
    "lint": "node scripts/lint-slides.mjs",
    "font:check": "node scripts/check-font-assets.mjs",
    "font:provenance:test": "node scripts/test-font-provenance.mjs",
    "font:provenance:verify": "node scripts/verify-font-provenance.mjs",
    "model:test": "node scripts/test-slide-model.mjs",
    "validation:test": "node scripts/test-validation-aggregation.mjs",
    "metadata:test": "node scripts/test-model-metadata-validation.mjs",
    "cardinality:test": "node scripts/test-cardinality-contract.mjs",
    "renderer:test": "node scripts/test-render-slidev.mjs",
    "pptx:build": "npm run content:build && node scripts/render-pptx.mjs",
    "pptx:test": "node scripts/test-render-pptx.mjs",
    "build": "npm run render && slidev build decks/ai-governance/slides.md --out ../../dist/ai-governance",
    "visual:capture": "npm run build && node scripts/capture-slide-screenshots.mjs",
    "visual:baseline:update": "npm run build && node scripts/visual-regression.mjs --update",
    "visual:baseline:check": "node scripts/check-visual-baselines.mjs",
    "visual:path:test": "node scripts/test-screenshot-path-containment.mjs",
    "visual:authority:test": "node scripts/test-visual-review-authority.mjs",
    "visual:authority:check": "node scripts/check-visual-review-authority.mjs",
    "visual:test": "npm run build && node scripts/visual-regression.mjs",
    "check:ci": "npm run font:check && npm run font:provenance:test && npm run content:check && npm run content:test && npm run model:test && npm run validation:test && npm run metadata:test && npm run cardinality:test && npm run renderer:test && npm run pptx:test && npm run lint && npm run render:check && npm run visual:baseline:check && npm run visual:path:test && npm run visual:authority:test && npm run visual:authority:check && npm run build",
    "check": "npm run check:ci && npm run visual:test"
  },
  "devDependencies": {
    "@slidev/cli": "52.18.0",
    "jszip": "3.10.1",
    "pixelmatch": "7.2.0",
    "playwright-core": "1.61.1",
    "pngjs": "7.0.0",
    "pptxgenjs": "4.0.1",
    "vue": "3.5.39"
  }
}
